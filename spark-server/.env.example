# コピーして .env を作る（.env は gitignore 済み）。
#
# NOTE: systemd の EnvironmentFile は値の後ろの "# ..." を剥がさない。
# コメントは KEY=VALUE と同じ行に書かず、必ず別行に置く。

PORT=8000

# --- STT (transformers + PyTorch Whisper) ---
WHISPER_MODEL=openai/whisper-large-v3
WHISPER_DEVICE=cuda
WHISPER_DTYPE=float16

# PCM リングバッファ全体の長さ (秒)
PCM_BUFFER_SEC=30.0

# --- VAD (Silero) パラメータ ---
# 何秒おきに VAD を走らせるか
VAD_TICK_SEC=0.5
# 発話終了から「区切れた」と判定するまでの余白 (秒)
VAD_SETTLE_SEC=0.5
# Silero の発話確率しきい値 (0.0〜1.0)、低いほど発話判定が緩い
VAD_THRESHOLD=0.5
# 発話を切る最小無音長 (ms)
VAD_MIN_SILENCE_MS=400
# 発話の最小長 (ms)。これより短いノイズは捨てる
VAD_MIN_SPEECH_MS=250
# 1 発話の最大長 (秒)。超えたら完結を待たずチャンクで順次 emit
# 大きめにすると文の途中でのぶつ切りが減り、自然な区切りで訳せる（遅延は増える）
VAD_MAX_UTTERANCE_SEC=14.0

# --- 翻訳段 (OpenAI 互換 endpoint: Ollama / vLLM) ---
# VLLM_BASE_URL を空にしておくと翻訳は無効化され、原語のまま返る。
# 現状は Ollama (systemd の ollama.service が 11434 で listen) を使用。
VLLM_BASE_URL=http://127.0.0.1:11434/v1
VLLM_MODEL=qwen2.5:14b
VLLM_TIMEOUT_SEC=20.0
# LLM に渡す直近の (原文,訳文) 組数。文脈で辻褄をそろえる。0 で無効。
TRANSLATE_HISTORY=3
