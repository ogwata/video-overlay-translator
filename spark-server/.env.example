# コピーして .env を作る（.env は gitignore 済み）。
PORT=8000

# --- STT (transformers + PyTorch Whisper) ---
WHISPER_MODEL=openai/whisper-large-v3
WHISPER_DEVICE=cuda
WHISPER_DTYPE=float16
STT_WINDOW_SEC=5.0      # 何秒ごとに転写を発火するか
STT_CONTEXT_SEC=8.0     # 1回の転写に渡す PCM の長さ (>= window)
PCM_BUFFER_SEC=30.0     # リングバッファ全体の長さ

# --- 翻訳段 (vLLM の OpenAI 互換 endpoint) ---
# VLLM_BASE_URL を空にしておくと翻訳は無効化され、原語のまま返る。
VLLM_BASE_URL=http://127.0.0.1:8001/v1
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_TIMEOUT_SEC=20.0
