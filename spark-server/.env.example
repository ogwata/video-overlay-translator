# コピーして .env を作る（.env は gitignore 済み）。
#
# NOTE: systemd の EnvironmentFile は値の後ろの "# ..." を剥がさない。
# コメントは KEY=VALUE と同じ行に書かず、必ず別行に置く。

PORT=8000

# --- STT (transformers + PyTorch Whisper) ---
WHISPER_MODEL=openai/whisper-large-v3
WHISPER_DEVICE=cuda
WHISPER_DTYPE=float16

# 何秒ごとに転写を発火するか
STT_WINDOW_SEC=5.0
# 1回の転写に渡す PCM の長さ (>= window)
STT_CONTEXT_SEC=8.0
# リングバッファ全体の長さ
PCM_BUFFER_SEC=30.0

# 無音判定の RMS しきい値（[0,1] 正規化済み音声基準、~ -46 dBFS）
SILENCE_RMS_THRESHOLD=0.005

# --- 翻訳段 (OpenAI 互換 endpoint: Ollama / vLLM) ---
# VLLM_BASE_URL を空にしておくと翻訳は無効化され、原語のまま返る。
# 現状は Ollama (systemd の ollama.service が 11434 で listen) を使用。
VLLM_BASE_URL=http://127.0.0.1:11434/v1
VLLM_MODEL=qwen2.5:14b
VLLM_TIMEOUT_SEC=20.0
